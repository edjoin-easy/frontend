    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
