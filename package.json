{
  "name": "frontend",
  "private": true,
  "version": "0.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "prettier": "prettier --cache --check \"./**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "preview": "vite preview",
    "format": "eslint . --fix && prettier --cache --write \"./**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "release": "make release"
  },
  "dependencies": {
